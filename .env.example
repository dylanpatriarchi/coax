# Copy to .env and fill in. .env is gitignored — never commit real credentials.

# --- LLM provider used by the policy oracle and the adaptive attacker (optional) ---
# Gauntlet runs fully offline without these; only the LLM-judge oracle and the
# adaptive attacker module need a live model.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
GAUNTLET_MODEL=gpt-4o-mini

# --- Cost / rate-limit guards for any LLM calls ---
GAUNTLET_MAX_LLM_CALLS=200
GAUNTLET_MAX_USD=1.00

# --- Responsible use ---
# Required to run against any non-localhost target. See README "Responsible use".
GAUNTLET_I_AM_AUTHORIZED=false
